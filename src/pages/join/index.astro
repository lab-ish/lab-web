---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import { href } from '../../lib/url';
import { useTranslations, getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const entry = await getEntry('section', 'join');
const data = entry?.data;
const { Content } = entry ? await render(entry) : { Content: null };

const subPages = [
  { label: t('nav.environment'), href: href('/join/environment') },
  { label: t('nav.labLife'), href: href('/join/lab-life') },
  { label: t('nav.impression'), href: href('/join/impression') },
];
---

<BaseLayout title={data?.title} heading={data?.title} updated={data?.updated}>
  <section class="mb-10 space-y-4">
    {data?.sections?.map((s) => <p class="text-sm">{s.body}</p>)}
    {
      Content && (
        <div class="text-sm leading-relaxed [&_p]:mb-4">
          <Content />
        </div>
      )
    }
  </section>

  <section class="grid gap-6 sm:grid-cols-3">
    {
      subPages.map((p) => (
        <a
          href={p.href}
          class="block rounded border border-line p-6 text-center hover:border-brand hover:bg-surface"
        >
          <span class="font-medium text-brand">{p.label}</span>
        </a>
      ))
    }
  </section>
</BaseLayout>
