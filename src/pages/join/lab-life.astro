---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('section', 'lab-life');
const data = entry?.data;
const schedule = data?.schedule ?? [];
const { Content } = entry ? await render(entry) : { Content: null };
---

<BaseLayout title={data?.title} heading={data?.title} updated={data?.updated}>
  {
    Content && (
      <div class="mb-8 text-sm leading-relaxed [&_p]:mb-4">
        <Content />
      </div>
    )
  }
  <div class="space-y-6">
    {
      schedule.map((s) => (
        <div>
          <h2 class="font-semibold text-brand">{s.month}</h2>
          <p class="text-sm">{s.body}</p>
        </div>
      ))
    }
  </div>
</BaseLayout>
