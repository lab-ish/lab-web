---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsList from '../components/NewsList.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { getImage } from 'astro:assets';
import { href } from '../lib/url';
import { useTranslations, getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allNews = (await getCollection('news')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const latestNews = allNews.slice(0, 3);

const links = await getEntry('section', 'links');
const contact = await getEntry('section', 'contact');

// 研究室紹介・コンタクトの本文（Markdown）を描画する。
const home = await getEntry('section', 'home');
const { Content: HomeBody } = home ? await render(home) : { Content: null };

// ヒーロー画像。photo=PC用 / photo-sm=スマホ用（ハンバーガー切替の md=768px を境に出し分け）。
const heroLg = home?.data.photo
  ? await getImage({ src: home.data.photo, format: 'webp', width: 1600 })
  : null;
const heroSm = home?.data['photo-sm']
  ? await getImage({ src: home.data['photo-sm'], format: 'webp', width: 800 })
  : null;
const { Content: ContactBody } = contact ? await render(contact) : { Content: null };
---

<BaseLayout>
  {/* ヒーロー（md=768px 以上で photo、未満で photo-sm） */}
  <section class="mb-12">
    {
      heroLg ? (
        <picture>
          <source media="(min-width: 768px)" srcset={heroLg.src} />
          <img
            src={(heroSm ?? heroLg).src}
            alt={home?.data.title}
            class="aspect-[16/7] w-full rounded object-cover"
            loading="eager"
          />
        </picture>
      ) : (
        <div class="flex aspect-[16/7] w-full items-center justify-center rounded bg-line text-muted">
          写真
        </div>
      )
    }
  </section>

  {/* 研究室紹介 */}
  {
    HomeBody && (
      <section class="mb-12">
        <div class="text-sm leading-relaxed [&_p]:mb-4">
          <HomeBody />
        </div>
      </section>
    )
  }

  {/* ニュース（最新3件） */}
  <section class="mb-12">
    <h2 class="mb-4 text-xl font-bold text-brand">{t('home.news')}</h2>
    <NewsList items={latestNews} />
    <div class="mt-4 text-right">
      <a href={href('/news')} class="text-sm text-brand-light underline"
        >{t('news.all')} →</a
      >
    </div>
  </section>

  {/* 関連サイト */}
  <section class="mb-12">
    <h2 class="mb-4 text-xl font-bold text-brand">{t('home.links')}</h2>
    <ul class="list-inside list-disc space-y-1 text-sm">
      {
        links?.data.links?.map((l) => (
          <li>
            <a href={l.url} class="text-brand-light underline" target="_blank" rel="noopener">
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  {/* コンタクト */}
  <section>
    <h2 class="mb-4 text-xl font-bold text-brand">{t('home.contact')}</h2>
    {
      ContactBody && (
        <div class="mb-4 text-sm leading-relaxed [&_p]:mb-4">
          <ContactBody />
        </div>
      )
    }
    <ul class="space-y-1 text-sm">
      {
        contact?.data.contacts?.map((c) => (
          <li class="flex gap-4">
            <span class="w-24 shrink-0">{c.name}</span>
            <p class="text-brand-light underline">
              {c.email}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
