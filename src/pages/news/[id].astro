---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { href } from '../../lib/url';
import { useTranslations, getLangFromUrl } from '../../i18n/utils';

export const getStaticPaths = (async () => {
  const news = await getCollection('news');
  return news.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props as { entry: CollectionEntry<'news'> };
const { Content } = await render(entry);
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const fmt = (d: Date) =>
  `${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, '0')}/${String(
    d.getDate(),
  ).padStart(2, '0')}`;
---

<BaseLayout title={entry.data.title} heading={entry.data.title}>
  <article>
    <p class="mb-6 text-sm text-muted">{fmt(entry.data.date)}</p>
    <div class="prose prose-sm max-w-none">
      <Content />
    </div>
  </article>

  <div class="mt-10">
    <a href={href('/news')} class="text-sm text-brand-light underline">
      ← {t('common.backToNews')}
    </a>
  </div>
</BaseLayout>
