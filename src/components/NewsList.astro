---
import type { CollectionEntry } from 'astro:content';
import { href } from '../lib/url';

interface Props {
  items: CollectionEntry<'news'>[];
}
const { items } = Astro.props;

const fmt = (d: Date) =>
  `${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, '0')}/${String(
    d.getDate(),
  ).padStart(2, '0')}`;
---

<ul class="divide-y divide-line">
  {
    items.map((n) => (
      <li>
        <a
          href={href(`/news/${n.id}`)}
          class="flex flex-col gap-1 py-4 hover:bg-surface sm:flex-row sm:items-baseline sm:gap-4"
        >
          <time class="shrink-0 border-line text-sm text-muted sm:w-28 sm:border-r sm:pr-4">
            {fmt(n.data.date)}
          </time>
          <span class="text-sm text-ink">{n.data.title}</span>
        </a>
      </li>
    ))
  }
</ul>
